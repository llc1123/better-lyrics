{
    "type": "module",
    "name": "better-lyrics",
    "version": "2.3.2",
    "description": "Enhance YouTube Music with beautiful time-synced lyrics, multilingual support, real-time translations and more",
    "scripts": {
        "generate:locales": "tsx tooling/generate-locales.ts",
        "dev": "npm run generate:locales && extension dev --browser chrome --polyfill",
        "dev:firefox": "npm run generate:locales && extension dev --browser firefox --polyfill",
        "dev:brave": "npm run generate:locales && extension dev --chromium-binary \"/Applications/Brave Browser.app/Contents/MacOS/Brave Browser\" --polyfill",
        "start": "npm run generate:locales && extension start --polyfill",
        "build": "npm run generate:locales && extension build --browser all --polyfill",
        "build:ci": "npm run generate:locales && tsx tooling/build-and-patch.ts",
        "build:zip": "npm run generate:locales && extension build --browser all --polyfill --zip",
        "build:release": "npm run generate:locales && tsx tooling/build-release-zip.ts",
        "preview": "npm run generate:locales && extension preview --polyfill",
        "lint": "biome lint --write . && biome format --write .",
        "update-version": "tsx tooling/update-version.ts",
        "typecheck": "npm run generate:locales && tsc --noEmit",
        "knip": "knip --cache",
        "knip:fix": "knip --fix",
        "knip:ci": "knip --no-exit-code --reporter github-actions"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/better-lyrics/better-lyrics.git"
    },
    "keywords": [
        "youtube-music",
        "chrome-extension",
        "better-lyrics"
    ],
    "author": "boidushya",
    "license": "GPL-3.0",
    "bugs": {
        "url": "https://github.com/better-lyrics/better-lyrics/issues"
    },
    "homepage": "https://github.com/better-lyrics/better-lyrics#readme",
    "dependencies": {
        "@codemirror/autocomplete": "^6.20.3",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lint": "^6.9.7",
        "@codemirror/search": "^6.7.1",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.43.1",
        "@formkit/auto-animate": "^0.9.0",
        "@fsegurai/codemirror-theme-material-dark": "^6.2.5",
        "@plasmohq/edge-addons-api": "^2.0.0",
        "codemirror-lang-rics": "^0.3.21",
        "dompurify": "^3.4.11",
        "extension": "2.1.3",
        "fast-xml-parser": "^5.9.3",
        "fflate": "^0.8.3",
        "marked": "^18.0.5",
        "rics": "^0.3.21",
        "sortablejs": "^1.15.7"
    },
    "devDependencies": {
        "@biomejs/biome": "2.0.4",
        "@types/chrome": "^0.2.0",
        "@types/jsdom": "^28.0.3",
        "@types/node": "^26.0.0",
        "@types/sortablejs": "^1.15.9",
        "@typescript/lib-dom": "npm:@types/web@^0.0.280",
        "jsdom": "^29.1.1",
        "knip": "^5.88.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    }
}
